# Copy to .env.local for local development.

# Supabase (local)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me

# App domains
NEXT_PUBLIC_APP_DOMAIN=app.ksiegai.pl
NEXT_PUBLIC_MARKETING_DOMAIN=www.ksiegai.pl

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# PostHog analytics (leave empty to disable; disabled locally by default in component)
NEXT_PUBLIC_POSTHOG_KEY=phc_replace_me
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
